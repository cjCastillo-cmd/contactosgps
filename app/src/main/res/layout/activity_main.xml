<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Toolbar con degradado -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="8dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/gradient_toolbar"
            app:titleTextColor="@color/white"
            app:title="@string/titulo_nuevo_contacto"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Foto circular con FAB de cámara -->
            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivFoto"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/ripple_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/foto_contacto"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/accent" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_camera_overlay"
                    android:contentDescription="@string/tomar_foto"
                    app:fabSize="mini"
                    app:backgroundTint="@color/accent"
                    app:tint="@color/white"
                    app:elevation="6dp"
                    app:ensureMinTouchTargetSize="true"
                    android:minHeight="48dp"
                    android:minWidth="48dp" />

            </FrameLayout>

            <!-- Chip de estado GPS -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipGps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gps_inactivo"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/gps_inactive"
                app:chipCornerRadius="20dp"
                app:chipIconTint="@color/white"
                app:chipIcon="@android:drawable/ic_menu_mylocation"
                android:layout_marginBottom="20dp"
                app:ensureMinTouchTargetSize="true" />

            <!-- Card del formulario -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Campo Nombre -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/RoundedOutlinedBox"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_nombre"
                            android:inputType="textPersonName"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Campo Teléfono -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/RoundedOutlinedBox"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTelefono"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_telefono"
                            android:inputType="phone"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Campo Latitud -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLatitud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/RoundedOutlinedBox"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/accent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLatitud"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_latitud"
                            android:enabled="false"
                            android:inputType="numberDecimal|numberSigned" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Campo Longitud -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLongitud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/RoundedOutlinedBox"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/accent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLongitud"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_longitud"
                            android:enabled="false"
                            android:inputType="numberDecimal|numberSigned" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- FAB de guardar -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabSalvar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:text="@string/btn_salvar"
        android:textColor="@color/white"
        app:icon="@android:drawable/ic_menu_save"
        app:iconTint="@color/white"
        app:backgroundTint="@color/save_green"
        app:shapeAppearanceOverlay="@style/RoundedFAB"
        app:elevation="8dp"
        android:contentDescription="@string/btn_salvar"
        app:ensureMinTouchTargetSize="true"
        android:minHeight="48dp"
        android:minWidth="48dp" />

    <!-- Bottom Bar -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:backgroundTint="@color/primary"
        app:fabAlignmentMode="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerContactos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_ver_contactos"
            android:textColor="@color/white"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconTint="@color/white"
            style="@style/Widget.Material3.Button.TextButton"
            app:rippleColor="@color/accent_light"
            android:minHeight="48dp"
            android:minWidth="48dp" />

    </com.google.android.material.bottomappbar.BottomAppBar>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
